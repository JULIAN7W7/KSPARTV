<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Formulario de compra - KSPARTV-JULI">
    <title>Comprar - KSPARTV-JULI</title>
    
    <!-- External CSS -->
    <link rel="stylesheet" href="css/styles.css">
    
    <style>
        .purchase-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--spacing-lg);
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8eb 100%);
        }
        
        .purchase-form {
            background-color: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: var(--radius-2xl);
            padding: var(--spacing-3xl);
            max-width: 500px;
            width: 100%;
            box-shadow: var(--shadow-xl);
        }
        
        .purchase-header {
            text-align: center;
            margin-bottom: var(--spacing-2xl);
        }
        
        .purchase-title {
            font-size: var(--font-size-3xl);
            font-weight: 700;
            color: var(--color-gray-dark);
            margin-bottom: var(--spacing-sm);
        }
        
        .purchase-subtitle {
            font-size: var(--font-size-base);
            color: var(--color-gray-medium);
        }
        
        .form-group {
            margin-bottom: var(--spacing-lg);
        }
        
        .form-label {
            display: block;
            font-size: var(--font-size-sm);
            font-weight: 600;
            color: var(--color-gray-dark);
            margin-bottom: var(--spacing-xs);
        }
        
        .form-input {
            width: 100%;
            padding: var(--spacing-md);
            font-size: var(--font-size-base);
            color: var(--color-gray-dark);
            background-color: var(--color-white);
            border: 2px solid rgba(0, 0, 0, 0.1);
            border-radius: var(--radius-md);
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }
        
        .form-input:focus {
            outline: none;
            border-color: var(--color-blue);
            box-shadow: var(--shadow-glow);
        }
        
        .form-input::placeholder {
            color: var(--color-gray-light);
        }
        
        .radio-group {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-sm);
        }
        
        .radio-option {
            display: flex;
            align-items: center;
            padding: var(--spacing-md);
            background-color: var(--color-white);
            border: 2px solid rgba(0, 0, 0, 0.1);
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: border-color var(--transition-fast), background-color var(--transition-fast);
        }
        
        .radio-option:hover {
            border-color: var(--color-blue-light);
            background-color: rgba(0, 113, 227, 0.05);
        }
        
        .radio-option.selected {
            border-color: var(--color-blue);
            background-color: rgba(0, 113, 227, 0.1);
        }
        
        .radio-option input[type="radio"] {
            margin-right: var(--spacing-md);
            width: 20px;
            height: 20px;
            accent-color: var(--color-blue);
        }
        
        .radio-label {
            flex: 1;
            font-size: var(--font-size-base);
            color: var(--color-gray-dark);
        }
        
        .radio-price {
            font-size: var(--font-size-sm);
            font-weight: 600;
            color: var(--color-blue);
        }
        
        .form-submit {
            width: 100%;
            padding: var(--spacing-md);
            font-size: var(--font-size-lg);
            font-weight: 600;
            color: var(--color-white);
            background: linear-gradient(135deg, var(--color-blue) 0%, var(--color-blue-dark) 100%);
            border: none;
            border-radius: var(--radius-full);
            cursor: pointer;
            transition: transform var(--transition-fast), box-shadow var(--transition-fast);
            box-shadow: var(--shadow-md), var(--shadow-glow);
        }
        
        .form-submit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg), var(--shadow-glow);
        }
        
        .form-submit:active {
            transform: translateY(0);
        }
        
        .form-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            pointer-events: none;
        }
        
        .back-link {
            display: block;
            text-align: center;
            margin-top: var(--spacing-lg);
            color: var(--color-gray-medium);
            text-decoration: none;
            font-size: var(--font-size-sm);
            transition: color var(--transition-fast);
        }
        
        .back-link:hover {
            color: var(--color-blue);
        }
        
        .error-message {
            color: #ff0000;
            font-size: var(--font-size-xs);
            margin-top: var(--spacing-xs);
            display: none;
        }
        
        .error-message.visible {
            display: block;
        }
        
        .form-group.error .form-input {
            border-color: #ff0000;
        }
        
        .form-group.error .error-message {
            display: block;
        }
        
        .internet-notice {
            padding: var(--spacing-md);
            background-color: rgba(255, 193, 7, 0.1);
            border: 2px solid #ffc107;
            border-radius: var(--radius-md);
            color: var(--color-gray-dark);
            font-size: var(--font-size-sm);
            line-height: 1.5;
        }
        
        .internet-notice strong {
            color: #f57c00;
        }
        
        .internet-notice small {
            color: var(--color-gray-medium);
        }
    </style>
</head>
<body>
    <div class="purchase-container">
        <form class="purchase-form" id="purchaseForm">
            <div class="purchase-header">
                <h1 class="purchase-title">Completar Compra</h1>
                <p class="purchase-subtitle">Selecciona tu opción y completa tus datos</p>
            </div>
            
            <div class="form-group">
                <label class="form-label">Tipo de TV</label>
                <div class="radio-group">
                    <label class="radio-option" id="optionAndroid">
                        <input type="radio" name="tvType" value="android" required>
                        <div>
                            <div class="radio-label">TV con Android (AndroidTV o Google TV)</div>
                            <div class="radio-price">110.000$ por año</div>
                        </div>
                    </label>
                    <label class="radio-option" id="optionDevice">
                        <input type="radio" name="tvType" value="device">
                        <div>
                            <div class="radio-label">TV sin Android (necesita dispositivo)</div>
                            <div class="radio-price">290.000$ primer año, luego 110.000$ anuales</div>
                        </div>
                    </label>
                </div>
            </div>
            
            <div class="form-group">
                <label class="form-label" for="name">Nombre</label>
                <input type="text" id="name" class="form-input" placeholder="Ingresa tu nombre" required>
                <div class="error-message">Por favor ingresa tu nombre</div>
            </div>
            
            <div class="form-group">
                <label class="form-label" for="phone">Número de Cedula</label>
                <input type="tel" id="phone" class="form-input" placeholder="Ingresa tu número de cedula" required>
                <div class="error-message">Por favor ingresa tu número de cedula</div>
            </div>
            
            <div class="form-group">
                <div class="internet-notice">
                    <strong>⚠️ ACUERDATE QUE PARA PODER USAR LA APLICACIÓN NECESITAS SÍ O SÍ TENER INTERNET EN TU CASA</strong><br>
                    <small>(Sin embargo, con datos también sirve pero preferiblemente, para mayor comodidad internet)</small>
                </div>
            </div>
            
            <button type="submit" class="form-submit" id="submitBtn">Comprar</button>
            
            <a href="index.html" class="back-link">← Volver al inicio</a>
        </form>
    </div>
    
    <script>
        // Form validation and submission
        const form = document.getElementById('purchaseForm');
        const submitBtn = document.getElementById('submitBtn');
        const radioOptions = document.querySelectorAll('.radio-option');
        
        // Handle radio option selection
        radioOptions.forEach(option => {
            const input = option.querySelector('input[type="radio"]');
            input.addEventListener('change', () => {
                radioOptions.forEach(opt => opt.classList.remove('selected'));
                if (input.checked) {
                    option.classList.add('selected');
                }
            });
        });
        
        // Form submission
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Get form values
            const tvType = document.querySelector('input[name="tvType"]:checked').value;
            const name = document.getElementById('name').value.trim();
            const phone = document.getElementById('phone').value.trim();
            
            // Validate
            let isValid = true;
            
            if (!name) {
                document.getElementById('name').closest('.form-group').classList.add('error');
                isValid = false;
            } else {
                document.getElementById('name').closest('.form-group').classList.remove('error');
            }
            
            if (!phone) {
                document.getElementById('phone').closest('.form-group').classList.add('error');
                isValid = false;
            } else {
                document.getElementById('phone').closest('.form-group').classList.remove('error');
            }
            
            if (!isValid) return;
            
            // Create WhatsApp message
            let optionText = '';
            if (tvType === 'android') {
                optionText = 'TV con Android (AndroidTV o Google TV) - 110.000$ por año';
            } else {
                optionText = 'TV sin Android (necesita dispositivo) - 290.000$ primer año, luego 110.000$ anuales';
            }
            
            const message = `Hola, estoy interesado en adquirir tu producto. Mi opción es: ${optionText}. Mi nombre es: ${name}. Mi número de cedula es: ${phone}`;
            
            // Redirect to WhatsApp
            const whatsappNumber = '573227147600';
            const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;
            window.open(whatsappUrl, '_blank');
        });
        
        // Remove error on input
        document.querySelectorAll('.form-input').forEach(input => {
            input.addEventListener('input', () => {
                input.closest('.form-group').classList.remove('error');
            });
        });
    </script>
</body>
</html>
